# =====================================================================
# GuildPay AI — environment template. Copy to .env and fill in.
# Secrets come from env vars ONLY. Never commit .env. Never hardcode keys.
# =====================================================================

# --- App ---
NODE_ENV=development
API_PORT=3001
DASHBOARD_PORT=3000
LOG_LEVEL=info

# --- WhatsApp: Meta Cloud API (primary) ---
CHANNEL_ADAPTER=meta            # meta | twilio
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
META_WABA_ID=
META_APP_SECRET=                # used to verify X-Hub-Signature-256
META_WEBHOOK_VERIFY_TOKEN=

# --- WhatsApp Flows: secure PIN entry (encrypted data-exchange endpoint) ---
# Leave WHATSAPP_PIN_FLOW_ID empty to disable Flows and use the chat-based PIN.
WHATSAPP_PIN_FLOW_ID=           # Flow ID from WhatsApp Manager after publishing pin-flow.json
WHATSAPP_FLOW_MODE=published    # published | draft (draft lets you test an unpublished Flow)
WHATSAPP_FLOW_PRIVATE_KEY=      # RSA-2048 private key PEM (use \n for newlines on one line)
WHATSAPP_FLOW_KEY_PASSPHRASE=   # passphrase for the private key (blank if unencrypted)
WHATSAPP_FLOW_TOKEN_SECRET=     # optional; HMAC secret for flow tokens (defaults to META_APP_SECRET)

# --- WhatsApp: Twilio Sandbox (fallback) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=           # e.g. whatsapp:+14155238886

# --- AI Providers (fallback order) ---
AI_PROVIDER_ORDER=groq,gemini          # comma-separated, tried left-to-right
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Speech-to-text (Voice Notes fallback order) ---
STT_PROVIDER_ORDER=groq,deepgram
DEEPGRAM_API_KEY=
# Note: Groq uses the same GROQ_API_KEY defined above for its audio endpoints.

# --- Database + Storage + Auth: Supabase ---
# Local dev: run `supabase start` (Supabase CLI) — the defaults below match its local stack.
# Or point these at the self-hosted Supabase on Guild Server.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=      # server-side only
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_MEDIA_BUCKET=guildpay-media

# --- Payments: Flutterwave (NGN rail) ---
# Live keys (FLWSECK-…) — requires an activated business with BVN/permanent-VA enabled.
MONEY_MODE=live                 # test | live — live requires activated business + enabled BVN/permanent-VA
FLW_SECRET_KEY=                 # FLWSECK-…
FLW_PUBLIC_KEY=                 # FLWPUBK-…
FLW_ENCRYPTION_KEY=
FLW_WEBHOOK_SECRET_HASH=        # value set as "secret hash" in the FLW dashboard; verifies verif-hash header
FLW_BASE_URL=https://api.flutterwave.com/v3
FLW_BVN_REDIRECT_URL=           # BVN consent-flow return URL, e.g. https://guildpay.guildserver.io/kyc/bvn-callback
# Merchant ops (dashboard Balances/Settlements/Disputes) + BVN/NIN verification
# reuse FLW_SECRET_KEY above — no extra keys needed. Live mode needs these enabled
# on the activated FLW business. Dispute webhooks arrive on the existing FLW webhook.

# --- Flutterwave v4 Wallets API (pick the virtual-account issuing bank) ---
# OPTIONAL. When FLW_V4_CLIENT_ID + FLW_V4_CLIENT_SECRET + FLW_VA_BANK_CODE are all
# set, NEW virtual accounts are created via the v4 Wallets API on the chosen bank.
# Leave any of them blank to stay on v3 (Flutterwave's default bank, e.g. Indulge MFB).
# Everything else (payouts, name enquiry, KYC, bills, ops) stays on v3.
FLW_V4_CLIENT_ID=               # dashboard: Settings → API Keys → switch v3 → v4
FLW_V4_CLIENT_SECRET=
FLW_V4_TOKEN_URL=https://idp.flutterwave.com/realms/flutterwave/protocol/openid-connect/token
FLW_V4_BASE_URL=https://f4bexperience.flutterwave.com   # live host
FLW_VA_BANK_CODE=               # issuing bank + v4 on/off flag: 035 = Wema, 232 = Sterling
FLW_V4_WEBHOOK_SECRET_HASH=     # v4 webhook "flutterwave-signature" secret (HMAC-SHA256)

# --- Cache / session: Redis (Upstash) ---
REDIS_URL=redis://localhost:6379

# --- Observability ---
SENTRY_DSN=

# --- Dashboard (Basic Auth gate) ---
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=
DASHBOARD_SESSION_TOKEN=

# --- Admin API ---
ADMIN_API_TOKEN=
API_INTERNAL_URL=http://guildpay-api:3001
