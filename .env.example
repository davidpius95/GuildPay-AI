# =====================================================================
# GuildPay AI — environment template. Copy to .env and fill in.
# Secrets come from env vars ONLY. Never commit .env. Never hardcode keys.
# =====================================================================

# --- App ---
NODE_ENV=development
API_PORT=3001
DASHBOARD_PORT=3000
LOG_LEVEL=info

# --- WhatsApp: Meta Cloud API (primary) ---
CHANNEL_ADAPTER=meta            # meta | twilio
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
META_WABA_ID=
META_APP_SECRET=                # used to verify X-Hub-Signature-256
META_WEBHOOK_VERIFY_TOKEN=

# --- WhatsApp: Twilio Sandbox (fallback) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=           # e.g. whatsapp:+14155238886

# --- AI Providers (fallback order) ---
AI_PROVIDER_ORDER=groq,gemini          # comma-separated, tried left-to-right
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=                 # Whisper (voice -> text)

# --- Database + Storage + Auth: Supabase ---
# Local dev: run `supabase start` (Supabase CLI) — the defaults below match its local stack.
# Or point these at the self-hosted Supabase on Guild Server.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=      # server-side only
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_MEDIA_BUCKET=guildpay-media

# --- Payments: Flutterwave (NGN rail) — use TEST/sandbox keys for the MVP ---
FLW_SECRET_KEY=                 # FLWSECK_TEST-...
FLW_PUBLIC_KEY=                 # FLWPUBK_TEST-...
FLW_ENCRYPTION_KEY=
FLW_WEBHOOK_SECRET_HASH=        # value set as "secret hash" in the FLW dashboard; verifies verif-hash header
FLW_BASE_URL=https://api.flutterwave.com/v3

# --- Cache / session: Redis (Upstash) ---
REDIS_URL=redis://localhost:6379

# --- Observability ---
SENTRY_DSN=
