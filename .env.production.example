# =====================================================================
# GuildPay AI — PRODUCTION env template for the Guild Server deploy.
# Copy to .env on the server:  cp .env.production.example .env  && edit.
# NEVER commit .env. Generate invented secrets with:  openssl rand -hex 24
# =====================================================================

# --- App ---
NODE_ENV=production
API_PORT=3001
DASHBOARD_PORT=3000
PUBLIC_BASE_URL=https://guildpay.guildserver.io
LOG_LEVEL=info

# --- WhatsApp: Meta Cloud API (primary) ---
CHANNEL_ADAPTER=meta            # meta | twilio
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
META_WABA_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=      # INVENT THIS — paste the same value into Meta's webhook config

# --- WhatsApp: Twilio Sandbox (fallback) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=           # whatsapp:+14155238886

# --- AI: Anthropic Claude (required, paid usage) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Speech-to-text: pick one ---
STT_PROVIDER=openai             # openai | local
OPENAI_API_KEY=                 # required if STT_PROVIDER=openai
STT_LOCAL_URL=http://guildpay-whisper:9000  # required if STT_PROVIDER=local

# --- Database + Storage + Auth: Supabase (self-hosted on Guild Server, or Supabase cloud) ---
# Create a GuildPay project/schema on your Supabase, then copy these from its API settings.
SUPABASE_URL=                   # e.g. https://<project>.supabase.co  or your self-hosted URL
SUPABASE_ANON_KEY=              # public anon key (dashboard client)
SUPABASE_SERVICE_ROLE_KEY=      # service-role key — SERVER-SIDE ONLY, never in the browser
# Postgres connection string for the same Supabase project (use the pooled/session URL).
DATABASE_URL=postgresql://postgres:<password>@<supabase-host>:5432/postgres

# --- Cache / session (self-hosted container) ---
REDIS_URL=redis://guildpay-redis:6379

# --- Payments: Flutterwave (NGN rail) — LIVE keys ---
FLW_PUBLIC_KEY=                 # FLWPUBK-...
FLW_SECRET_KEY=                 # FLWSECK-...
FLW_ENCRYPTION_KEY=
FLW_WEBHOOK_SECRET_HASH=        # INVENT THIS — paste the same value into Flutterwave webhook settings
FLW_BASE_URL=https://api.flutterwave.com/v3
FLW_BVN_REDIRECT_URL=           # e.g. https://guildpay.guildserver.io/kyc/bvn-callback

# --- Flutterwave v4 Wallets API (choose the virtual-account issuing bank) ---
# Set all three (client id/secret + bank code) to issue NEW accounts via v4 on the
# chosen bank; leave blank to stay on v3. See docs / plan for the rollout steps.
FLW_V4_CLIENT_ID=
FLW_V4_CLIENT_SECRET=
FLW_V4_TOKEN_URL=https://idp.flutterwave.com/realms/flutterwave/protocol/openid-connect/token
FLW_V4_BASE_URL=https://f4bexperience.flutterwave.com   # live host — verify with real creds
FLW_VA_BANK_CODE=               # 035 = Wema, 232 = Sterling
FLW_V4_WEBHOOK_SECRET_HASH=     # v4 webhook signature secret (register URL /webhooks/flutterwave/v4)

# --- WhatsApp Flows: secure PIN entry (encrypted data-exchange endpoint) ---
WHATSAPP_PIN_FLOW_ID=           # Flow ID from WhatsApp Manager after publishing pin-flow.json
WHATSAPP_FLOW_MODE=published    # published | draft (draft lets you test an unpublished Flow)
WHATSAPP_FLOW_PRIVATE_KEY=      # RSA-2048 private key PEM (use \n for newlines on one line)
WHATSAPP_FLOW_KEY_PASSPHRASE=   # passphrase for the private key (blank if unencrypted)

# --- Dashboard (Basic Auth gate; public route) ---
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=
DASHBOARD_SESSION_TOKEN=

# --- Admin API (reset/delete users; also powers /v1/demo/reset) ---
ADMIN_API_TOKEN=
API_INTERNAL_URL=http://guildpay-api:3001

# --- Media storage: Supabase Storage (bucket for voice/image/xlsx) ---
MEDIA_STORAGE=supabase          # supabase | local
SUPABASE_MEDIA_BUCKET=guildpay-media

# --- Observability (optional) ---
SENTRY_DSN=

